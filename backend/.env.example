# ─────────────────────────────────────────────────────────────────
# MediRoute AI — Backend Environment Variables
# Copy this file to: backend/.env
# NEVER commit the real .env file to GitHub!
# ─────────────────────────────────────────────────────────────────

# ── Frontend URL (for CORS) ──────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev is included by default if left empty.
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Example for production:
# FRONTEND_URL=https://mediroute-ai.vercel.app

# ── n8n Webhook ──────────────────────────────────────────────────
# Leave EMPTY to use the built-in local heuristic routing (works without n8n)
# Paste your n8n Cloud Production URL here when ready:
N8N_WEBHOOK_URL=

# Example:
# N8N_WEBHOOK_URL=https://yourname.app.n8n.cloud/webhook/triage

# ── Supabase ─────────────────────────────────────────────────────
# Leave EMPTY to simulate database saves locally
SUPABASE_URL=
SUPABASE_KEY=

# Example:
# SUPABASE_URL=https://abcdefghijkl.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Port (Render sets this automatically) ────────────────────────
# PORT=8000
